flowchart LR
    subgraph INPUT["📡 Input Sources"]
        RTSP["RTSP Camera\nStream"]
        MIC["🎤 Microphone\nFeed"]
    end

    subgraph CAPTURE["📹 Frame Capture"]
        FE["Adaptive Frame\nExtractor"]
        FPS["Dynamic FPS\nAdjustment"]
        MOCK["Mock RTSP\n(Dev Mode)"]
        FE --> FPS
        MOCK -.-> FE
    end

    subgraph DETECTION["🔍 Detection Pipeline"]
        YOLO["YOLO-World v2\nOpen-Vocab Detection"]
        YOLO11["YOLO11\nFallback Detector"]
        VITPOSE["ViTPose++\nPose Estimation"]
        QWEN["Qwen2.5-VL-3B\nEdge VLM"]
        
        YOLO --> VITPOSE
        YOLO11 -.-> VITPOSE
        YOLO --> QWEN
    end

    subgraph AUDIO_P["🔊 Audio Processing"]
        BEATS["BEATs / AST\nClassifier"]
        CLASSES["gunshot · glass_break\nscream · alarm\nvoice · vehicle"]
    end

    subgraph PRIVACY["🔒 Privacy Engine"]
        SCRFD["InsightFace SCRFD\nFace Detection"]
        PLATE["YOLO Plate\nDetector"]
        BLUR["Gaussian Blur\nAnonymization"]
        SCRFD --> BLUR
        PLATE --> BLUR
    end

    subgraph OUTPUT["📤 Event Output"]
        EVT["VisionEvent\nConstruction"]
        B64["Keyframe\nBase64 Encode"]
        PUBSUB["GCP Pub/Sub\nEmitter"]
        EVT --> B64
        B64 --> PUBSUB
    end

    RTSP --> CAPTURE
    MIC --> AUDIO_P
    CAPTURE --> DETECTION
    DETECTION --> PRIVACY
    PRIVACY --> OUTPUT
    AUDIO_P --> OUTPUT
    BEATS --> CLASSES

