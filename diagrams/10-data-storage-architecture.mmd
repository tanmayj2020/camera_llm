flowchart TB
    subgraph APP["Application Layer"]
        API_S["FastAPI\n(55+ Services)"]
        GO_S["Go Event\nProcessor"]
    end

    subgraph GRAPH_STORE["📊 Graph Store — Neo4j 5"]
        KG_NODES["Entity Nodes\n(person, vehicle, object)"]
        KG_EDGES["Bi-Temporal Edges\n(valid_from, valid_to)"]
        KG_REL["Relationships\nnear | following | blocking\napproaching | handing_object_to"]
        KG_QUERY["Cypher Queries\n+ Graph Walks"]
    end

    subgraph VECTOR_STORE["🔮 Vector Store — Qdrant"]
        VEC_KEY["Keyframe Embeddings\n(SigLIP visual encoder)"]
        VEC_ALERT["Alert Embeddings\n(GTE-Qwen2 text)"]
        VEC_ENTITY["Entity Embeddings\n(re-ID features)"]
        VEC_SCENE["Scene Embeddings\n(Deja Vu engine)"]
        HNSW["HNSW Index\n(fast ANN search)"]
    end

    subgraph RELATIONAL["🗃️ PostgreSQL + pgvector"]
        PG_CONFIG["Configuration\n(cameras, zones, rules)"]
        PG_TRACKER["Custom Trackers\n(NL rule definitions)"]
        PG_WEBHOOK["Webhooks\n(endpoints, delivery logs)"]
        PG_AUDIT["Audit Trail\n(search unlocks, auth)"]
        PG_CONSENT["GDPR Consent\n(entity consent records)"]
        PG_VEC["pgvector Extension\n(inline vector queries)"]
    end

    subgraph OBJECT_STORE["📦 GCS (Google Cloud Storage)"]
        GCS_KEY["Keyframe Images\n(camera_id/event_id.jpg)"]
        GCS_EVIDENCE["Evidence Packages\n(HTML bundles)"]
        GCS_MODELS["Model Artifacts\n(edge deployment)"]
    end

    subgraph ANALYTICS_STORE["📈 BigQuery"]
        BQ_EVENTS["Events Table\n(all processed events)"]
        BQ_METRICS["Metrics Table\n(KPIs, occupancy)"]
        BQ_QUERY["SQL Analytics\n(historical queries)"]
    end

    API_S --> GRAPH_STORE
    API_S --> VECTOR_STORE
    API_S --> RELATIONAL
    GO_S --> OBJECT_STORE
    GO_S --> ANALYTICS_STORE

