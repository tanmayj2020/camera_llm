flowchart TB
    subgraph NL_RULES["📝 Natural Language Rule Compiler"]
        direction LR
        NL_IN["Plain English Input\n'Alert when someone loiters\nnear exit after 10pm'"]
        PARSE_NL["LLM Parser\n→ Structured Rule"]
        COMPILED["Compiled Rule\n{type: loitering,\nduration: 180s,\ntime: 22:00-06:00,\nzone: exit}"]
        TOGGLE["Active/Inactive\nToggle"]
        NL_IN --> PARSE_NL --> COMPILED --> TOGGLE
    end

    subgraph AMBIENT["🎯 Ambient Intelligence Score"]
        direction TB
        SIG1["👥 Crowd Density"]
        SIG2["🔴 Anomaly Count"]
        SIG3["🔊 Audio Alerts"]
        SIG4["⏱️ Dwell Anomaly"]
        SIG5["💡 Lighting Quality"]
        SIG6["🦺 Compliance Rate"]
        SIG7["🏃 Velocity Anomaly"]
        SIG8["🚶 Loitering Count"]
        SIG9["📊 Historical Risk"]
        BAYESIAN["Bayesian Fusion\nWeighted Combination"]
        SCORE["Safety Score\n0.0 → 1.0\nper Zone"]
        
        SIG1 & SIG2 & SIG3 --> BAYESIAN
        SIG4 & SIG5 & SIG6 --> BAYESIAN
        SIG7 & SIG8 & SIG9 --> BAYESIAN
        BAYESIAN --> SCORE
    end

    subgraph PREDICT_I["🚨 Predictive Interception"]
        TRAJ["Current Trajectory\n(position + velocity)"]
        EXTRAP["Linear Extrapolation\n(5–30s lookahead)"]
        POLY["Restricted Zone\nPolygon Geometry"]
        PIP["Point-in-Polygon\nRay Casting"]
        PRE_ALERT["Pre-emptive Alert\n(before entry occurs)"]
        TRAJ --> EXTRAP
        EXTRAP --> PIP
        POLY --> PIP
        PIP --> PRE_ALERT
    end

    subgraph GAIT_D["🧬 Gait DNA Biometrics"]
        POSE_SEQ["Pose Sequence\n(10+ observations)"]
        FEATURES["Feature Extraction\nstride_length · cadence\narm_swing · torso_sway\nhip_ratio · bounce\nfoot_clearance · symmetry"]
        FINGERPRINT["32-D Movement\nFingerprint"]
        GALLERY["Gait Gallery\n(re-identification\nwithout face/clothing)"]
        POSE_SEQ --> FEATURES --> FINGERPRINT --> GALLERY
    end

    subgraph CONTAGION_N["🔗 Anomaly Contagion Network"]
        ZONE_A["Zone A\nAnomaly Detected"]
        PROP["Bayesian Propagation\nP(B|A) increases"]
        ZONE_B["Zone B\nElevated Risk"]
        ZONE_C["Zone C\nCascade Alert"]
        GRAPH_VIS["Propagation Graph\nVisualization"]
        ZONE_A --> PROP --> ZONE_B
        PROP --> ZONE_C
        ZONE_B & ZONE_C --> GRAPH_VIS
    end

    subgraph DEJAVU_E["♻️ Deja Vu Engine"]
        CURRENT["Current Scene\nEmbedding"]
        DB_HIST["Historical Scene\nDatabase"]
        COSINE["Cosine Similarity\nMatching"]
        MATCH["Similar Past Incident\nFound (score > 0.7)"]
        CONTEXT_M["Contextual Warning\n'This pattern preceded\na theft on March 12'"]
        CURRENT --> COSINE
        DB_HIST --> COSINE
        COSINE --> MATCH --> CONTEXT_M
    end

    style NL_RULES fill:#1e3a5f,stroke:#4a9eff,color:#fff
    style AMBIENT fill:#2d1b69,stroke:#9b59b6,color:#fff
    style PREDICT_I fill:#3c1a1a,stroke:#e74c3c,color:#fff
    style GAIT_D fill:#1a3c34,stroke:#2ecc71,color:#fff
    style CONTAGION_N fill:#3c3c1a,stroke:#f1c40f,color:#fff
    style DEJAVU_E fill:#1a1a2e,stroke:#e94560,color:#fff
