# VisionBrain Environment Configuration
# Copy to .env and fill in values

# ---- GCP ----
GCP_PROJECT=your-gcp-project-id
PUBSUB_TOPIC=visionbrain-events
PUBSUB_SUBSCRIPTION=visionbrain-events-sub
GCS_KEYFRAME_BUCKET=visionbrain-keyframes
BIGQUERY_DATASET=visionbrain
BIGQUERY_EVENTS_TABLE=events

# ---- Neo4j ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # REQUIRED: set a strong password

# ---- Qdrant ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=visionbrain-keyframes

# ---- PostgreSQL (production) ----
# Comment out to use SQLite for development
# DATABASE_URL=postgresql://user:password@localhost:5432/visionbrain

# ---- Auth ----
AUTH_ENABLED=false
JWT_SECRET=  # REQUIRED when AUTH_ENABLED=true

# ---- Edge ----
RTSP_URL=rtsp://localhost:8554/stream
DETECTION_CONFIDENCE=0.3

# ---- Observability (optional) ----
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=visionbrain
